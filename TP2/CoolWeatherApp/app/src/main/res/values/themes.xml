<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CoolWeatherApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryVariant">@color/dark_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <item name="background">@color/viewBG</item>
        <item name="android:textColor">@color/WeatherLabel</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.Day" parent="Theme.CoolWeatherApp">
        <item name="android:windowBackground">@drawable/wallpaper_day</item>
    </style>

    <style name="Theme.Day.Land" parent="Theme.CoolWeatherApp">
        <item name="android:windowBackground">@drawable/wallpaper_day_landscape</item>
    </style>

    <style name="Theme.Night" parent="Theme.CoolWeatherApp">
        <item name="android:windowBackground">@drawable/wallpaper_night</item>
    </style>

    <style name="Theme.Night.Land" parent="Theme.CoolWeatherApp">
        <item name="android:windowBackground">@drawable/wallpaper_night_landscape</item>
    </style>
</resources>